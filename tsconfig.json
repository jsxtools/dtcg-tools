{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": false,
		"exactOptionalPropertyTypes": true,
		"incremental": true,
		"lib": ["ES2024", "WebWorker"],
		"module": "preserve",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"preserveConstEnums": false,
		"rootDir": "src",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "es2024",
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
